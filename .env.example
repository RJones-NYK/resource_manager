# App environment — copy to .env.local on MacBook (dev)
#
# Access: no app login. Postgres and the UI are intended to run only on the
# Tailscale tailnet. See README.md § Access and security.

# development | production — shown in the header environment badge
APP_ENV=development

# Mac Mini Postgres via Tailscale — replace hostname and password
DATABASE_URL=postgres://rm_admin:YOUR_PASSWORD@YOUR-MAC-MINI:5432/resource_manager_dev
